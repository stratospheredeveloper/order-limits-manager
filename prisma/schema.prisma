// This is your Prisma schema file for PRODUCTION (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PrepShipmentStatus {
  Pending
  Prepped
  Shipped
}

model Shop {
  id                 String   @id
  name               String
  email              String?
  accessToken        String?
  grantedScopes      String?
  installedAt        DateTime?
  subscriptionId     String?
  subscriptionStatus String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  rules              Rule[]
  settings           Settings?
  prepShipments      PrepShipment[]
}

model Rule {
  id              String   @id @default(uuid())
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  ruleType        String   // "product", "collection", "variant", "cart"
  targetId        String?  // Product ID, Collection ID, or Variant ID (null for cart-wide)
  targetTitle     String?  // Display name
  minQuantity     Int?
  maxQuantity     Int?
  enabled         Boolean  @default(true)
  message         String?  // Custom error message
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopId])
  @@index([shopId, enabled, ruleType], map: "Rule_shopId_enabled_ruleType_idx")
}

model Settings {
  id                    String   @id @default(uuid())
  shop                  Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId                String   @unique
  globalMinCart         Int?
  globalMaxCart         Int?
  showCartWarning       Boolean  @default(true)
  blockCheckout         Boolean  @default(true)
  customMessageEnabled  Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PrepShipment {
  id          String             @id @default(uuid())
  shipmentId  String             @map("shipment_id")
  units       Int
  status      PrepShipmentStatus @default(Pending)
  shopOrigin  String             @map("shop_origin")
  shop        Shop               @relation(fields: [shopOrigin], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([shipmentId, shopOrigin])
  @@index([shopOrigin])
}
